---
import Base from "../../layouts/Base.astro";
import CardNoticia from "../../components/CardNoticia.astro";
import CardVideo from "../../components/CardVideo.astro";
import { CATEGORIAS } from "../../content/config";
import { noticiasPorCategoria, videosBlocoTematico } from "../../lib/conteudo";
import { slugCategoria, corCategoria } from "../../lib/site";

export async function getStaticPaths() {
  return CATEGORIAS.map((cat) => ({
    params: { categoria: slugCategoria(cat) },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const noticias = await noticiasPorCategoria(cat);
const videosTema = await videosBlocoTematico(cat);
const cor = corCategoria(cat);
const lead = noticias[0];
const resto = noticias.slice(1);
---

<Base
  titulo={cat}
  ativo={cat}
  descricao={`Ultimas noticias de ${cat} no GPlay Newsletter.`}
  preloadImagem={lead?.data.imagem}
>
  <h1 class="section-title" style={`color:${cor}`}>{cat}</h1>

  {
    noticias.length === 0 ? (
      <p class="aviso" style="margin-top:10px">Nenhuma noticia de {cat} ainda. Rode <code>npm run coletar</code>.</p>
    ) : (
      <>
        {lead && (
          <div class="grid" style="gap:16px;margin-bottom:8px">
            <CardNoticia entry={lead} destaque nivelTitulo={2} prioridadeLcp={Boolean(lead.data.imagem)} />
            {resto.slice(0, 4).length > 0 && (
              <div class="grid grid--3">
                {resto.slice(0, 4).map((n) => <CardNoticia entry={n} nivelTitulo={2} />)}
              </div>
            )}
          </div>
        )}
        {resto.length > 4 && (
          <div class="grid grid--3" style="margin-top:24px">
            {resto.slice(4).map((n) => <CardNoticia entry={n} nivelTitulo={2} />)}
          </div>
        )}
      </>
    )
  }

  {
    videosTema.length > 0 && (
      <>
        <h2 class="section-title" style="margin-top:32px">
          Videos
          <a href="/categoria/youtube">ver tudo no YouTube →</a>
        </h2>
        <div class="grid grid--3">
          {videosTema.map((v) => (
            <CardVideo entry={v} nivelTitulo={2} />
          ))}
        </div>
      </>
    )
  }
</Base>
