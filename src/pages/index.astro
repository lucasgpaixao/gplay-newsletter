---
import Base from "../layouts/Base.astro";
import CardNoticia from "../components/CardNoticia.astro";
import CardVideo from "../components/CardVideo.astro";
import EventoFocoCapa from "../components/EventoFocoCapa.astro";
import EventoTeaserCapa from "../components/EventoTeaserCapa.astro";
import { CATEGORIAS } from "../content/config";
import { noticiasPublicadas, videosPublicados, videosDestaqueCapa } from "../lib/conteudo";
import {
  eventoEmFoco,
  eventoTeaserCapa,
  noticiasDoEvento,
  videosDoEvento,
} from "../lib/eventos";
import { slugCategoria, COR_YOUTUBE, NAV_YOUTUBE } from "../lib/site";

const noticias = await noticiasPublicadas();
const videos = await videosPublicados();
const foco = await eventoEmFoco();
const teaser = foco ? null : await eventoTeaserCapa();
const coberturaFoco = foco
  ? {
      noticias: noticiasDoEvento(foco, noticias),
      videos: videosDoEvento(foco, videos),
    }
  : null;

const videosCapa = await videosDestaqueCapa();
const videoLead = videosCapa[0];
const videosSecundarios = videosCapa.slice(1);

const lead = noticias[0];
const secundarias = noticias.slice(1, 5);
const recentes = noticias.slice(5, 17);

const porCategoria = CATEGORIAS.map((c) => ({
  cat: c,
  itens: noticias.filter((n) => n.data.categoria === c).slice(0, 3),
})).filter((g) => g.itens.length > 0);
---

<Base ativo="capa" preloadImagem={lead?.data.imagem}>
  {
    noticias.length === 0 && (
      <p class="aviso" style="margin-top:28px">
        Ainda nao ha noticias coletadas. Rode <code>npm run coletar</code> para popular o jornal.
      </p>
    )
  }

  {
    foco && coberturaFoco && (
      <EventoFocoCapa
        entry={foco}
        noticias={coberturaFoco.noticias}
        videos={coberturaFoco.videos}
      />
    )
  }

  {teaser && <EventoTeaserCapa entry={teaser} />}

  {
    lead && (
      <>
        <h2 class="section-title">Manchetes</h2>
        <div class="grid" style="gap:16px">
          <CardNoticia entry={lead} destaque prioridadeLcp={Boolean(lead.data.imagem)} />
          {secundarias.length > 0 && (
            <div class="grid grid--3">
              {secundarias.map((n) => <CardNoticia entry={n} />)}
            </div>
          )}
        </div>
      </>
    )
  }

  {
    videoLead && (
      <>
        <h2 class="section-title" style={`color:${COR_YOUTUBE}`}>
          {NAV_YOUTUBE}
          <a href="/categoria/youtube">ver tudo →</a>
        </h2>
        <div class="grid" style="gap:16px">
          <CardVideo entry={videoLead} destaque prioridadeLcp />
          {videosSecundarios.length > 0 && (
            <div class="grid grid--3">
              {videosSecundarios.map((v) => <CardVideo entry={v} />)}
            </div>
          )}
        </div>
      </>
    )
  }

  {
    recentes.length > 0 && (
      <>
        <h2 class="section-title">Mais recentes</h2>
        <div class="grid grid--3">
          {recentes.map((n) => <CardNoticia entry={n} />)}
        </div>
      </>
    )
  }

  {
    porCategoria.map((g) => (
      <>
        <h2 class="section-title">
          {g.cat}
          <a href={`/categoria/${slugCategoria(g.cat)}`}>ver tudo →</a>
        </h2>
        <div class="grid grid--3">
          {g.itens.map((n) => (
            <CardNoticia entry={n} />
          ))}
        </div>
      </>
    ))
  }
</Base>
