---
import Base from "../layouts/Base.astro";
import EventoCard from "../components/EventoCard.astro";
import CardNoticia from "../components/CardNoticia.astro";
import { eventosOrdenados, noticiasPublicadas, noticiasDoEvento, proximosEventos } from "../lib/conteudo";

const noticias = await noticiasPublicadas();
const proximos = await proximosEventos();
const todos = await eventosOrdenados();
const agora = Date.now();
const passados = todos.filter((e) => {
  const fim = e.data.fim ?? new Date(e.data.inicio.getTime() + 2 * 60 * 60 * 1000);
  return fim.getTime() < agora;
});
---

<Base titulo="Eventos" ativo="eventos" descricao="Cobertura especial: State of Play, Summer Game Fest, Copa do Mundo e mais.">
  <h1 class="section-title">Cobertura Especial — Eventos</h1>

  <div class="grid" style="gap:16px">
    {proximos.map((e) => {
      const rel = noticiasDoEvento(e, noticias).slice(0, 3);
      return (
        <div>
          <EventoCard entry={e} nivelTitulo={2} />
          {rel.length > 0 && (
            <div class="grid grid--3" style="margin-top:14px">
              {rel.map((n) => <CardNoticia entry={n} />)}
            </div>
          )}
        </div>
      );
    })}
  </div>

  {
    passados.length > 0 && (
      <>
        <h2 class="section-title">Eventos encerrados</h2>
        <div class="grid" style="gap:14px">
          {passados.map((e) => <EventoCard entry={e} />)}
        </div>
      </>
    )
  }
</Base>
