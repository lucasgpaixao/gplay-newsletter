---
import type { CollectionEntry } from "astro:content";
import { corCategoria, slugCategoria, tempoRelativo } from "../lib/site";

interface Props {
  entry: CollectionEntry<"noticias">;
  destaque?: boolean;
}

const { entry, destaque = false } = Astro.props;
const d = entry.data;
const cor = corCategoria(d.categoria);
const href = `/noticia/${entry.slug}`;
const inicialCat = d.categoria.charAt(0);
---

<article class={`card${destaque ? " card--lead" : ""}`}>
  <a class="card__media" href={href} style={d.imagem ? `background-image:url('${d.imagem}')` : `background:${cor}`}>
    {!d.imagem && <span class="card__ph">{inicialCat}</span>}
  </a>
  <div class="card__body">
    <div>
      <a href={`/categoria/${slugCategoria(d.categoria)}`}>
        <span class="chip" style={`background:${cor}`}>{d.categoria}</span>
      </a>
    </div>
    <h3 class="card__title">
      <a href={href}>{d.titulo}</a>
    </h3>
    {destaque && d.resumo && <p class="card__resumo">{d.resumo}</p>}
    <div class="card__meta">
      <span>{d.fonte}</span>
      <span>·</span>
      <span>{tempoRelativo(d.publicado)}</span>
    </div>
  </div>
</article>
